# Kestra Environment Variables
# Copy this file to .env and fill in your values

# GCP Configuration (from Terraform outputs)
GCS_BUCKET_NAME=aq_data_lake_air-quality-project-491604
SERVICE_ACCOUNT_EMAIL=

# Service Account Key (Base64 encoded)
# Get this from: terraform output service_account_key
# Then encode it: echo "your-json-key-content" | base64 -w 0
SERVICE_ACCOUNT_KEY=